# Criptografia de campos sensíveis (CPF) — OBRIGATÓRIO
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=<gere-uma-chave-fernet>

